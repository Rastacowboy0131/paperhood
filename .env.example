# RH chain RPC (QuickNode)
RH_RPC_HTTP=
RH_RPC_WSS=
# Postgres (optional; sqlite fallback used when unset)
DATABASE_URL=
# Auth (web)
# JWT_SECRET signs session cookies (required in prod). SIWE_DOMAIN optionally
# pins the domain field of Sign-In with Ethereum messages, e.g. app.paperhood.xyz
JWT_SECRET=
SIWE_DOMAIN=
